{
  "name": "@diemrt/harness",
  "version": "0.5.0",
  "description": "Controlled AI-agent development harness: issue tracker, task runner, and agent rules, installable with npx.",
  "type": "module",
  "license": "MIT",
  "author": "diemrt",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diemrt/harness"
  },
  "homepage": "https://github.com/diemrt/harness#readme",
  "bugs": {
    "url": "https://github.com/diemrt/harness/issues"
  },
  "keywords": [
    "harness",
    "ai-agent",
    "scaffold",
    "cli",
    "issue-tracker",
    "npx",
    "boilerplate"
  ],
  "bin": {
    "harness": "src/cli.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src/",
    "template/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test",
    "dev:sync": "node src/cli.mjs update .",
    "dev:check": "node src/cli.mjs update . --dry-run --json"
  },
  "publishConfig": {
    "access": "public"
  }
}
