{
  "_comment": "Configurazione dei task eseguiti da init.ps1. Personalizza i 'command' per il tuo stack (Node, Python, Go, .NET, ...). Ogni task ha una 'workingDirectory' opzionale (relativa alla cartella dello script, default '.') e una lista ordinata di 'steps'. Ogni step ha 'description' (mostrata a video) e 'command' (riga eseguita nella shell). Se un comando esce con codice diverso da 0, il task si ferma con errore.",
  "tasks": {
    "setup": {
      "workingDirectory": ".",
      "steps": [
        {
          "description": "Install dependencies",
          "command": "npm install"
        },
        {
          "description": "Install git hooks",
          "command": "node hooks/install.mjs"
        }
      ]
    },
    "build": {
      "workingDirectory": ".",
      "steps": [
        {
          "description": "Run test suite",
          "command": "npm test"
        }
      ]
    }
  },
  "externalWorker": {
    "enabled": false,
    "command": "copilot --yolo --model auto -p {promptFile}"
  },
  "docsGate": {
    "enabled": true,
    "include": [
      "**/*.mjs",
      "**/*.js",
      "**/*.cjs",
      "**/*.ts",
      "**/*.tsx",
      "**/*.jsx",
      "**/*.py",
      "**/*.go",
      "**/*.cs",
      "**/*.java",
      "**/*.rb",
      "**/*.rs",
      "**/*.php"
    ],
    "exclude": [
      "docs/**",
      "test/**",
      "tests/**",
      "**/*.md",
      "issues.json",
      ".harness-manifest.json"
    ]
  }
}
